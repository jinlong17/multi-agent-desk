{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MultiAgentDesk",
  "version": "0.0.0",
  "identifier": "com.multiagentdesk.app",
  "build": {
    "beforeBuildCommand": "pnpm --dir ../.. --filter @multi-agent-desk/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    },
    "windows": [
      {
        "label": "main",
        "title": "MultiAgentDesk scaffold",
        "width": 960,
        "height": 640
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
