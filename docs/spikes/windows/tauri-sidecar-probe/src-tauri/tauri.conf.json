{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MultiAgentDesk Sidecar Spike",
  "version": "0.0.0",
  "identifier": "com.multiagentdesk.sidecar-spike",
  "build": {
    "frontendDist": "../assets"
  },
  "app": {
    "security": {
      "csp": "default-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "MultiAgentDesk Sidecar Spike",
        "visible": false,
        "width": 320,
        "height": 240
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/mad-sidecar"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
